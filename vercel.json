{
  "headers": [
    {
      "source": "/OneSignalSDKWorker.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/install.html",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "none" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/send-notifications.js": {
      "maxDuration": 30
    }
  }
}
